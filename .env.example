# ============================================================
# 업무일지 자동화 - 환경변수 설정
# ============================================================
# 이 파일은 팀 공통 설정입니다.
# 개인별 인증 정보는 앱 실행 후 OAuth 또는 설정 화면에서 입력하세요.
# ============================================================

# Slack OAuth App (https://api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=

# OpenRouter (팀 공통)
OPENROUTER_API_KEY=sk-or-v1-your-key

# ============================================================
# 아래는 E2E 테스트용 (개발자만 사용)
# 일반 사용자는 앱에서 직접 입력하세요
# ============================================================

# Remote.com (E2E 테스트용)
REMOTE_EMAIL=
REMOTE_PASSWORD=
